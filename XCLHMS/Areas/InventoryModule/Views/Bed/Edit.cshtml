@model XCLHMS.Models.Bed

@{
    ViewBag.Title = "Edit";
}

<div style="font-family:Arial">
    <h2>Edit</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal">
            <h4>Bed</h4>
            <hr />
            @Html.ValidationSummary(true)
            @Html.HiddenFor(model => model.ID)

            <div class="form-group">
                @Html.LabelFor(model => model.WardId, "Select Ward", new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.DropDownList("WardId", null, "--Select--", new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.WardId)
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.BedNumber, new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.TextBoxFor(model => model.BedNumber, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.BedNumber)
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.Description, new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.TextAreaFor(model => model.Description, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Description)
                </div>
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.IsOccupied, new { @class = "control-label col-md-2" })
                <div class="col-md-10">
                    @Html.CheckBox("IsOccupied")
                    @Html.ValidationMessageFor(model => model.IsOccupied)
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Save" class="btn btn-primary btn-success" />
                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary btn-large" })
                </div>
            </div>
        </div>
    }

</div>