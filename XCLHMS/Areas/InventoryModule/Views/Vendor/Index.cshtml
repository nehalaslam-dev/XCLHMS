@*@model IEnumerable<XCLHMS.Models.Vendor>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Vendor List</h2>

    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Supplier Name</th>
                        <th>Code</th>
                        <th>Contact#</th>
                        <th>Email</th>
                        <th>Contact Person</th>
                        <th>Active</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())

    </div>    
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/Vendor/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(7)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(7)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(8)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(8)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },
                "columns": [

                    { "data": "Name", "autoWidth": true },
                    { "data": "Code", "autoWidth": true },
                    { "data": "ContactNo", "autoWidth": true },
                    { "data": "Email", "autoWidth": true },
                    { "data": "ContactPerson", "autoWidth": true },
                    { "data": "Active", "autoWidth": true },
                     {
                         "render": function (data, type, full, meta)
                         { return '<a class="btn btn-info" href="/InventoryModule/Vendor/Details/' + full.Id + '">Details</a>'; }
                     },
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info btnEdit" href="/InventoryModule/Vendor/Edit/' + full.Id + '">Edit</a>'; }
                      },
                       {
                           data: null, render: function (data, type, row) {
                               return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.Id + '"); >Delete</a>';
                           }
                       },
                ]
            });
           
        });

     

        function DeleteData(vendorId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(vendorId);
            }
            else {
                return false;
            }
        }

        function Delete(vendorId) {
            var url = "/Vendor/Delete";
            $.post(url, { Id: vendorId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/InventoryModule/Vendor/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}