@*@model IEnumerable<XCLHMS.Models.PO>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Purchase Order List</h2>

    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Vendor</th>
                        <th>PONO</th>
                        <th>PO Date</th>
                        @*<th>Total Amount</th>
                        <th>IsComplete</th>*@
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())   
    </div>    
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/PO/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(6)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(6)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(7)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(7)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },
                "columns": [
                    { "data": "vendorName", "autoWidth": true },
                    { "data": "PONO", "autoWidth": true },
                    {
                        "data": "PODate",
                        "type": "date",
                        "render": function (value) {
                            if (value === null) return "";

                            var pattern = /Date\(([^)]+)\)/;
                            var results = pattern.exec(value);
                            var dt = new Date(parseFloat(results[1]));
                            return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                        }
                    },
                     //{ "data": "TotalAmount", "autoWidth": true },
                     //{ "data": "IsComplete", "autoWidth": true },
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/InventoryModule/PO/Details/' + full.Id + '">Details</a>'; }
                      },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info btnEdit" href="/InventoryModule/PO/Create/' + full.Id + '">Edit</a>'; }
                       },                     
                       {
                           data: null, render: function (data, type, row) {
                               return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.Id + '"); >Delete</a>';
                           }
                       },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info" href="/InventoryModule/PO/LoadReport?Id=' + full.Id + '">Report</a>'; }
                       },
                ]
            });
          
        });

     

        function DeleteData(poId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(poId);
            }
            else {
                return false;
            }
        }

        function Delete(poId) {
            var url = "/PO/Delete";
            $.post(url, { Id: poId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/InventoryModule/PO/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }

    </script>
}
