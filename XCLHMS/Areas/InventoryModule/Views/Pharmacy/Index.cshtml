@*@model IEnumerable<XCLHMS.Models.Pharmacy>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="font-family:Arial">
    <h2>Pharmacy List</h2>

    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Medicine</th>
                        <th>Patient Name</th>
                        <th>Recieve Date</th>
                        <th>Issue Date</th>
                        <th>Qty Recieved</th>
                        <th>Qty Issued</th>
                        <th>Commnets</th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>
@section Scripts{

    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/Pharmacy/LoadGrid",
                    "type": "GET",
                    "datatype": "json",
                },
                "columns": [
                 { "data": "productName", "autoWidth": true },
                 
                 { "data": "patientname", "autoWidth": true },
                 {
                     "data": "recDate",
                     "type": "date",
                     "render": function (value) {
                         if (value === null) return "";

                         var pattern = /Date\(([^)]+)\)/;
                         var results = pattern.exec(value);
                         var dt = new Date(parseFloat(results[1]));
                         return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                     }
                 },
                  {
                      "data": "issueDate",
                      "type": "date",
                      "render": function (value) {
                          if (value === null) return "";

                          var pattern = /Date\(([^)]+)\)/;
                          var results = pattern.exec(value);
                          var dt = new Date(parseFloat(results[1]));
                          return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                      }
                  },
                 { "data": "qtyRec", "autoWidth": true },
                 { "data": "qtyIssue", "autoWidth": true },                     
                 { "data": "comments", "autoWidth": true },
                {
                    "render": function (data, type, full, meta)
                    { return '<a class="btn btn-info" href="/InventoryModule/Pharmacy/Edit/' + full.Id + '">Edit</a>'; }
                }

                ]
            });
        });
    </script>
}