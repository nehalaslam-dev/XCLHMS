@*@model IEnumerable<XCLHMS.Models.BedManagement>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Bed Allocation List</h2>

    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Patient Name</th>
                        <th>MR #</th>
                        <th>Ward</th>
                        <th>Bed Number</th>
                        <th>Admit Date</th>
                        <th>Discharge Status</th>
                        <th>Discharge Date</th>                     
                        <th class="th-width"></th>
                      
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())
       
    </div>
  </div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/BedManagement/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(4)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(4)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(5)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(5)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },
                "columns": [

                     { "data": "patientName", "autoWidth": true },
                      { "data": "MRNo", "autoWidth": true },
                     { "data": "WardName", "autoWidth": true },
                     { "data": "BedNumber", "autoWidth": true },
                     {
                         "data": "AllotmentDate",
                         "type": "datetime",
                         "render": function (value) {
                             if (value === null) return "";

                             var pattern = /Date\(([^)]+)\)/;
                             var results = pattern.exec(value);
                             var dt = new Date(parseFloat(results[1]));
                             return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear() + " " + dt.getHours() + ":" + dt.getMinutes() + ":" + dt.getSeconds();
                         }
                     },
                      { "data": "dischargeType", "autoWidth": true },
                      {
                          "data": "DischargeDate",
                          "type": "datetime",
                          "render": function (value) {
                              if (value === null) return "";

                              var pattern = /Date\(([^)]+)\)/;
                              var results = pattern.exec(value);
                              var dt = new Date(parseFloat(results[1]));
                              return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                          }
                      },                                    
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info btnEdit" href="/InventoryModule/BedManagement/Edit/' + full.ID + '">Edit</a>'; }
                      },
                       //{
                       //    data: null, render: function (data, type, row) {
                       //        return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.ID + '"); >Delete</a>';

                       //    }
                       //},
                ]
            });
            
        });

   

        function DeleteData(bedmgmtId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(bedmgmtId);
            }
            else {
                return false;
            }
        }

        function Delete(bedmgmtId) {
            var url = "/BedManagement/Delete";
            $.post(url, { Id: bedmgmtId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/InventoryModule/BedManagement/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}