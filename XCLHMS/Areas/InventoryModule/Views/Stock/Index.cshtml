@*@model IEnumerable<XCLHMS.Models.Stock>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="font-family:Arial">
    <h2>Stock List</h2>

    <p style="float:right;">
        @Html.ActionLink("Stock Summary", "GetStockSummary", null, new { @class = "btn btn-primary btn-large" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Items</th>
                        <th>Stock Date</th>
                        <th>Batch #</th>
                        <th>Manufacture Date</th>
                        <th>Expiry Date</th>
                        <th>Qty In</th>
                        <th>Qty Out</th>
                        <th>Issued To</th>
                        <th>Status</th>
                        <th>Expired</th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>
@section Scripts{

    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/Stock/LoadGrid",
                    "type": "GET",
                    "datatype": "json",
                },
                "columnDefs": [
                    { "visible": false, "targets": 9 }
                ],
                "fnRowCallback": function (nRow, aData, iDisplayIndex, iDisplayIndexFull) {
                    if (aData.isexpired == 1) {
                        $('td', nRow).css('background-color', 'yellow');
                    }

                },
                "columns": [
                 { "data": "productName", "autoWidth": true },
                 {
                     "data": "stockDate",
                     "type": "date",
                     "render": function (value) {
                         if (value === null) return "";

                         var pattern = /Date\(([^)]+)\)/;
                         var results = pattern.exec(value);
                         var dt = new Date(parseFloat(results[1]));
                         return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                     }
                 },
                 { "data": "batchNo", "autoWidth": true },
                   {
                       "data": "mfgDate",
                       "type": "date",
                       "render": function (value) {
                           if (value === null) return "";

                           var pattern = /Date\(([^)]+)\)/;
                           var results = pattern.exec(value);
                           var dt = new Date(parseFloat(results[1]));
                           return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                       }
                   },
                    {
                        "data": "expiryDate",
                        "type": "date",
                        "render": function (value) {
                            if (value === null) return "";

                            var pattern = /Date\(([^)]+)\)/;
                            var results = pattern.exec(value);
                            var dt = new Date(parseFloat(results[1]));
                            return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                        }
                    },
                     { "data": "QtyIn", "autoWidth": true },
                      { "data": "QtyOut", "autoWidth": true },
                      { "data": "IssuedTo", "autoWidth": true },
                        { "data": "tranType", "autoWidth": true },
                        { "data": "isexpired", "autoWidth": true },
                          {
                              "render": function (data, type, full, meta)
                              { return '<a class="btn btn-info" href="/InventoryModule/Stock/Edit/' + full.Id + '">Edit</a>'; }
                          }

                ]
            });
        });


