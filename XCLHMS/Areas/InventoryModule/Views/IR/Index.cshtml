@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>

<div style="font-family:Arial">
    <h2>Challan List</h2>

    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>

    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Customer</th>
                        <th>IRNO</th>
                        <th>IR Date</th>
                        <th>Remarks</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())
        
    </div>
</div>
@section Scripts{
    <script>
        $(document).ready(function () {


            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/IR/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    //if (_valIsEdit == '1') {

                    //    $('td:eq(3)', nRow).find('a').removeAttr('disabled');
                    //}
                    //else {
                    //    $('td:eq(3)', nRow).find('a').attr('disabled', 'disabled');
                    //}

                    if (_valIsDelete == '1') {
                        $('td:eq(7)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(7)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },
                "columns": [
                    { "data": "Id", "autoWidth": true },
                    { "data": "customerName", "autoWidth": true },
                    { "data": "irCode", "autoWidth": true },
                    {
                        "data": "irDate",
                        "type": "date",
                        "render": function (value) {
                            if (value === null) return "";

                            var pattern = /Date\(([^)]+)\)/;
                            var results = pattern.exec(value);
                            var dt = new Date(parseFloat(results[1]));
                            return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                        }
                    },
                     { "data": "Remarks", "autoWidth": true },
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/InventoryModule/IR/Details/' + full.Id + '">Details</a>'; }
                      },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a id="btnEdit" class="btn btn-info btnEdit" href="/InventoryModule/IR/Create/' + full.Id + '">Edit</a>'; }
                       },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a  class='btn btn-danger btnDelete' onclick=DeleteData('" + row.Id + "','" + row.irCode + "'); >Delete</a>";
                           }
                       },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info" href="/InventoryModule/IR/LoadReport?Id=' + full.Id + '">Report</a>'; }
                       },
                ]
            });
           
        });

      

        setTimeout(function () {
            $.ajax({
                url: "/InventoryModule/IR/IRList",
                type: "GET",
                dataType: 'json',
                data: { id: 0 },
                success: function (data) {
                    $.each(data, function (index1, item1) {
                        var _ID = item1.sid;
                        var _isEdit = item1.isEdit
                      
                        $('#demoGrid tr').each(function (i, el) {
                            var IdForGrid = $(this).find('td:eq(0)').text();
                            if (IdForGrid.length > 0) {                             
                                if (parseInt(IdForGrid) == parseInt(_ID)) {
                                    if (_isEdit == '0') {
                                        $(this).find('.btnEdit').attr('disabled', 'disabled');
                                    }
                                    else {

                                        $(this).find('.btnEdit').removeAttr('disabled');
                                    }
                                }
                            }
                        });

                    });
                },
                error: function () {
                    alert("Error! Fetching records.")
                }
            });
        }, 1200);

        function DeleteData(irId, refCode) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(irId, refCode);
            }
            else {
                return false;
            }
        }

        function Delete(irId, refCode) {
            var url = "/IR/Delete";
            $.post(url, { Id: irId, RefCode: refCode }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/InventoryModule/IR/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }

    </script>
}
