@*@model IEnumerable<XCLHMS.Models.PostMartam>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="font-family:Arial">
    <h2>Post Mortem List</h2>
    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>NO</th>
                        <th>Mortem Date</th>
                        <th>Name</th>
                        <th>Age</th>
                        <th>Letter #</th>
                        <th>Police Station</th>
                        <th>Arrival DateTime</th>
                        <th>Mortem Started</th>
                        <th>Mortem Finished</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())
       
    </div>
</div>

@section Scripts{

    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/Martam/LoadGrid",
                    "type": "GET",
                    "datatype": "json",
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(9)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(9)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(10)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(10)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },


                "columns": [
                       { "data": "martamNo", "autoWidth": true },
                      {
                          "data": "martamDate",
                          "type": "date",
                          "render": function (value) {
                              if (value === null) return "";

                              var pattern = /Date\(([^)]+)\)/;
                              var results = pattern.exec(value);
                              var dt = new Date(parseFloat(results[1]));
                              return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                          }
                      },
                        { "data": "Name", "autoWidth": true },
                        { "data": "Age", "autoWidth": true },
                        { "data": "letterNo", "autoWidth": true },
                        { "data": "policeStation", "autoWidth": true },
                          {
                              "data": "ArrivalDateTime",
                              "type": "date",
                              "render": function (value) {
                                  if (value === null) return "";

                                  var pattern = /Date\(([^)]+)\)/;
                                  var results = pattern.exec(value);
                                  var dt = new Date(parseFloat(results[1]));
                                  return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                              }
                          },
                          { "data": "martamStart", "autoWidth": true },
                          { "data": "martamEnd", "autoWidth": true },

                        {
                            "render": function (data, type, full, meta)
                            { return '<a class="btn btn-info btnEdit" href="/MLCModule/Martam/Edit/' + full.Id + '">Edit</a>'; }
                        },
                         {
                             data: null, render: function (data, type, row) {
                                 return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.Id + '"); >Delete</a>';
                             }
                         },
                          {
                              "render": function (data, type, full, meta)
                              { return '<a class="btn btn-info" href="/MLCModule/Martam/LoadReport?Id=' + full.Id + '">Report</a>'; }
                          },
                ]


            });

        });

        

        function DeleteData(mortemId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(mortemId);
            }
            else {
                return false;
            }
        }

        function Delete(mortemId) {
            var url = '@Url.Content("~/")' + "Martam/Delete";
            $.post(url, { Id: mortemId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/MLCModule/Martam/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}