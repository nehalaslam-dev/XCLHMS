@*@model IEnumerable<XCLHMS.Models.EmployeeRole>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Employee Role List</h2>
    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Designation</th>
                        <th>Is Default</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/EmployeeRole/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                    { "data": "empName", "autoWidth": true },
                    { "data": "desgName", "autoWidth": true },
                    { "data": "isDefault", "autoWidth": true },
                   

                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/EmployeeModule/EmployeeRole/Edit/' + full.Id + '">Edit</a>'; }
                      },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(roleId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(roleId);
            }
            else {
                return false;
            }
        }

        function Delete(roleId) {
            var url = "/EmployeeRole/Delete";
            $.post(url, { Id: roleId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/EmployeeModule/EmployeeRole/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}


