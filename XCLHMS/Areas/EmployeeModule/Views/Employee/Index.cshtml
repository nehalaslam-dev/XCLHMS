@*@model IEnumerable<XCLHMS.Models.Employee>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">

    <h2>Employee List</h2>

    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Designation</th>
                        <th>Department</th>
                        <th>Employee Type</th>
                        <th>Code</th>
                        <th>Grade</th>
                        <th>Salary</th>
                        <th>Contact#</th>
                        <th>Appoint Date</th>
                        <th>Active</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())       
    </div>
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/Employee/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(11)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(11)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(12)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(12)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },
                "columns": [
                    { "data": "Name", "autoWidth": true },
                    { "data": "designationName", "autoWidth": true },
                    { "data": "departmentName", "autoWidth": true },
                    { "data": "empType", "autoWidth": true },
                    { "data": "empCode", "autoWidth": true },
                    { "data": "Grade", "autoWidth": true },
                    { "data": "Salary", "autoWidth": true },
                    { "data": "ContactNo", "autoWidth": true },
                    {
                        "data": "AppDate",
                        "type": "date",
                        "render": function (value) {
                            if (value === null) return "";

                            var pattern = /Date\(([^)]+)\)/;
                            var results = pattern.exec(value);
                            var dt = new Date(parseFloat(results[1]));
                            return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                        }
                    },
                     { "data": "Active", "autoWidth": true },
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/EmployeeModule/Employee/Details/' + full.Id + '">Details</a>'; }
                      },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info btnEdit" href="/EmployeeModule/Employee/Edit/' + full.Id + '">Edit</a>'; }
                       },
                       {
                           data: null, render: function (data, type, row) {
                               return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.Id + '"); >Delete</a>';
                           }
                       },
                ]
            });
           
        });


        function DeleteData(empId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(empId);
            }
            else {
                return false;
            }
        }

        function Delete(empId) {
            var url = "/Employee/Delete";
            $.post(url, { Id: empId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/EmployeeModule/Employee/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}