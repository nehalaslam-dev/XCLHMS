@section Scripts{
<script src="~/Scripts/moment.js"></script>
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/DutyShift/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                   { "data": "shiftName", "autoWidth": true },
                   { "data": "dutyshiftName", "autoWidth": true },
                   { "data": "Description", "autoWidth": true },
                     {
                         "title": "Start Time",
                         "data": "StartTime",
                         render: function (d) {
                             return moment(d).format("HH:mm:ss");
                         }
                     },
                      {
                          "title": "End Time",
                          "data": "EndTime",
                          render: function (d) {
                              return moment(d).format("HH:mm:ss");
                          }
                      },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info" href="/EmployeeModule/DutyShift/Edit/' + full.Id + '">Edit</a>'; }
                       },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(dutyId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(dutyId);
            }
            else {
                return false;
            }
        }

        function Delete(dutyId) {
            var url = "/DutyShift/Delete";
            $.post(url, { Id: dutyId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/EmployeeModule/DutyShift/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}