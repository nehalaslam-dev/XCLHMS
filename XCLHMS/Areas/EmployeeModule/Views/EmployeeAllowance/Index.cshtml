@*@model IEnumerable<XCLHMS.Models.EmployeeAllowance>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Allowance List</h2>
    <p>
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Employee Type</th>
                        <th>HouseRent</th>
                        <th>Conveyance</th>
                        <th>Casuality</th>
                        <th>Entertaiment</th>
                        <th>NonPracticing</th>
                        <th>RCA</th>
                        <th>Medical</th>
                        <th>Uniform</th>
                        <th>Mess</th>
                        <th>Nursing</th>
                        <th>Health</th>
                        <th>Institute</th>
                        <th>Hardworking</th>
                        <th>Orderly</th>
                        <th>SeniorPost</th>
                        <th>Washing</th>
                        <th>Computer</th>
                        <th>HPA</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>   
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/EmployeeAllowance/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                    { "data": "EmpType", "autoWidth": true },
                    { "data": "HouseRent", "autoWidth": true },
                    { "data": "Conveyance", "autoWidth": true },
                    { "data": "Casuality", "autoWidth": true },
                    { "data": "Entertaiment", "autoWidth": true },
                    { "data": "NonPracticing", "autoWidth": true },
                    { "data": "RCA", "autoWidth": true },
                    { "data": "Medical", "autoWidth": true },
                    { "data": "Uniform", "autoWidth": true },
                    { "data": "Mess", "autoWidth": true },
                    { "data": "Nursing", "autoWidth": true },
                    { "data": "Health", "autoWidth": true },
                    { "data": "Institute", "autoWidth": true },
                    { "data": "Hardworking", "autoWidth": true },
                    { "data": "Orderly", "autoWidth": true },
                    { "data": "SeniorPost", "autoWidth": true },
                    { "data": "Washing", "autoWidth": true },
                    { "data": "Computer", "autoWidth": true },
                    { "data": "HPA", "autoWidth": true },

                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/EmployeeModule/EmployeeAllowance/Edit/' + full.Id + '">Edit</a>'; }
                      },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(allowanceId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(allowanceId);
            }
            else {
                return false;
            }
        }

        function Delete(allowanceId) {
            var url = "/EmployeeAllowance/Delete";
            $.post(url, { Id: allowanceId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/EmployeeModule/EmployeeAllowance/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}
