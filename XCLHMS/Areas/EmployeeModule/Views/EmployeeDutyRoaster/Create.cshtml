@model XCLHMS.Models.EmployeeDutyRoaster

@{
    ViewBag.Title = "Create";
}

<h2>Create</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Employee Duty Roaster</h4>
        <hr />
        @Html.ValidationSummary(true)

        <div class="form-group">
            @Html.LabelFor(model => model.EmployeeId, "Select Employee", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("EmployeeId", (IEnumerable<SelectListItem>)ViewBag.EmployeeId, "--Select--", new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.EmployeeId)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.PeriodId, "Select Shift", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("PeriodId", null , new { @class = "form-control" })    
                @Html.ValidationMessageFor(model => model.PeriodId)           
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.ShiftId, "Select Duty Shift", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("ShiftId", null, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.ShiftId)     
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.InTime, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.InTime, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.InTime)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.OutTime, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.OutTime, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.OutTime)
            </div>
        </div>



        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Save" id="submitbtn" class="btn btn-primary btn-success" />
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary btn-large" })
            </div>
        </div>
    </div>
}
@section Scripts{
    <script>
        $(document).ready(function () {
            if ($("#PeriodId").val() == '0') {
                var dutyDefaultValue = "<option value='0'>--Select shift first--</option>";
                $("#ShiftId").html(dutyDefaultValue).show();
            }

            $('#submitbtn').click(function () {
                if ($("#PeriodId").val() == '0') {
                    alert('Please select shift.');
                    $("#PeriodId").focus();
                    return false;
                }
            });

            $("#PeriodId").change(function () {
                var selectedItemValue = $(this).val();
                var ddlShift = $("#ShiftId");
                $.ajax({
                    cache: false,
                    type: "GET",
                    url: "/EmployeeModule/EmployeeDutyRoaster/GetShiftByPeriodId",
                    data: { "id": selectedItemValue },
                    success: function (data) {
                        ddlShift.html('');
                        $.each(data, function (id, option) {
                            ddlShift.append($('<option></option>').val(option.id).html(option.name));
                        });
                    },
                    error: function (xhr, ajaxOptions, thrownError) {
                        alert('Found error to load shifts!!.');
                    }
                });
            });
        });

    </script>
}
