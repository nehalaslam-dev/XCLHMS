@section Scripts{
    <script src="~/Scripts/moment.js"></script>
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/EmployeeDutyRoaster/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [
                   { "data": "employee", "autoWidth": true },
                   { "data": "shiftPeriod", "autoWidth": true },
                   { "data": "dutyShift", "autoWidth": true },
                    {
                        "title": "Time In",
                        "data": "timeIn",
                        render: function (d) {
                            return moment(d).format("HH:mm:ss");
                        }
                    },
                    {
                        "title": "Time Out",
                        "data": "timeout",
                        render: function (d) {
                            return moment(d).format("HH:mm:ss");
                        }
                    },
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/EmployeeModule/EmployeeDutyRoaster/Edit/' + full.Id + '">Edit</a>'; }
                      },
                        {
                            data: null, render: function (data, type, row) {
                                return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                            }
                        },
                ]
            });
        });

        function DeleteData(rId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(rId);
            }
            else {
                return false;
            }
        }

        function Delete(rId) {
            var url = "/EmployeeDutyRoaster/Delete";
            $.post(url, { Id: rId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/EmployeeModule/EmployeeDutyRoaster/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}