@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/ShiftPeriod/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                  { "data": "Name", "autoWidth": true },
                  { "data": "Description", "autoWidth": true },
                  { "data": "Active", "autoWidth": true },
                   {
                       "render": function (data, type, full, meta)
                       { return '<a class="btn btn-info" href="/EmployeeModule/ShiftPeriod/Edit/' + full.Id + '">Edit</a>'; }
                   },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(shiftid) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(shiftid);
            }
            else {
                return false;
            }
        }

        function Delete(shiftid) {
            var url = "/ShiftPeriod/Delete";
            $.post(url, { Id: shiftid }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/EmployeeModule/ShiftPeriod/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}
