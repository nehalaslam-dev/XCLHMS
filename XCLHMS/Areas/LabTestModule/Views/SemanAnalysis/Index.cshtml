@*@model IEnumerable<XCLHMS.Models.SemanAnalysi>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Seman Analysis List</h2>
    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Lab</th>
                        <th>Patient</th>
                        <th>Ref.By Dr</th>
                        <th>NIC</th>
                        <th>MR#</th>
                        <th>Test Date</th>
                        <th>Sample Collection Date</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/SemanAnalysis/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                    { "data": "labName", "autoWidth": true },
                    { "data": "patientName", "autoWidth": true },
                     { "data": "doctorName", "autoWidth": true },
                    { "data": "nic", "autoWidth": true },
                    { "data": "mrno", "autoWidth": true },
                    {
                        "data": "testdate",
                        "type": "date",
                        "render": function (value) {
                            if (value === null) return "";

                            var pattern = /Date\(([^)]+)\)/;
                            var results = pattern.exec(value);
                            var dt = new Date(parseFloat(results[1]));
                            return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                        }
                    },
                     {
                         "data": "sampleDate",
                         "type": "date",
                         "render": function (value) {
                             if (value === null) return "";

                             var pattern = /Date\(([^)]+)\)/;
                             var results = pattern.exec(value);
                             var dt = new Date(parseFloat(results[1]));
                             return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                         }
                     },
                   
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/LabTestModule/SemanAnalysis/Details/' + full.Id + '">Details</a>'; }
                      },
                     {
                         "render": function (data, type, full, meta)
                         { return '<a class="btn btn-info" href="/LabTestModule/SemanAnalysis/Edit/' + full.Id + '">Edit</a>'; }
                     },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info" href="/LabTestModule/SemanAnalysis/LoadReport?Id=' + full.Id + '">Report</a>'; }
                       },
                ]
            });
        });

        function DeleteData(testId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(testId);
            }
            else {
                return false;
            }
        }

        function Delete(testId) {
            var url = "/SemanAnalysis/Delete";
            $.post(url, { Id: testId }, function (data) {
                if (data == "Deleted") {
                    window.location.href = '/LabTestModule/SemanAnalysis/Index'
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}