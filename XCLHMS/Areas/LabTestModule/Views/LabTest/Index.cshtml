@*@model IEnumerable<XCLHMS.Models.LabTest>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Lab Test List</h2>
    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Lab</th>
                        <th>Patient</th>
                        <th>MR#</th>
                        <th>NIC</th>
                        <th>Test Category</th>
                        <th>Prescribe By</th>
                        <th>Conduct By</th>
                        <th>Description</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
   
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/LabTest/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                    { "data": "LabName", "autoWidth": true },
                    { "data": "pateintName", "autoWidth": true },
                    { "data": "mrno", "autoWidth": true },
                    { "data": "nic", "autoWidth": true },
                    { "data": "testName", "autoWidth": true },
                    { "data": "prescribdBy", "autoWidth": true },
                    { "data": "conductBy", "autoWidth": true },
                    { "data": "description", "autoWidth": true },
                     {
                         "render": function (data, type, full, meta)
                         { return '<a class="btn btn-info" href="/LabTestModule/LabTest/Edit/' + full.Id + '">Edit</a>'; }
                     },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(labId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(labId);
            }
            else {
                return false;
            }
        }

        function Delete(labId) {
            var url = "/LabTest/Delete";
            $.post(url, { Id: labId }, function (data) {
                if (data == "Deleted") {
                    window.location.href = '/LabTestModule/LabTest/Index'
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}