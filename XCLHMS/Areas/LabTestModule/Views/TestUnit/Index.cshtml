</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/TestUnit/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [

                    { "data": "UnitName", "autoWidth": true },
                    { "data": "Description", "autoWidth": true },
                     {
                         "render": function (data, type, full, meta)
                         { return '<a class="btn btn-info" href="/LabTestModule/TestUnit/Edit/' + full.Id + '">Edit</a>'; }
                     },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a href='#' class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(unitId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(unitId);
            }
            else {
                return false;
            }
        }

        function Delete(unitId) {
            var url = "/TestUnit/Delete";
            $.post(url, { Id: unitId }, function (data) {
                if (data == "Deleted") {
                    window.location.href = '/LabTestModule/TestUnit/Index'
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>

}