@*@model IEnumerable<XCLHMS.Models.LabRegistration>*@

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Lab Registration List</h2>
    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Pateint Name</th>
                        <th>NIC</th>
                        <th>MR#</th>
                        <th>Reg#</th>
                        <th>Reg Date</th>
                        <th>Delivery Date</th>
                        <th>Contact#</th>
                        <th>Created On</th>
                        @*<th class="th-width"></th>
                        <th class="th-width"></th>*@
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())

    </div>
</div>
@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/LabRegistration/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');

                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(7)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(7)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(8)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(8)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },
                "columns": [
                   { "data": "pateintname", "autoWidth": true },
                   { "data": "nic", "autoWidth": true },
                    { "data": "mrno", "autoWidth": true },
                    { "data": "regno", "autoWidth": true },
                     {
                         "data": "regdate",
                         "type": "date",
                         "render": function (value) {
                             if (value === null) return "";

                             var pattern = /Date\(([^)]+)\)/;
                             var results = pattern.exec(value);
                             var dt = new Date(parseFloat(results[1]));
                             return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                         }
                     },
                      {
                          "data": "deliveryDate",
                          "type": "date",
                          "render": function (value) {
                              if (value === null) return "";

                              var pattern = /Date\(([^)]+)\)/;
                              var results = pattern.exec(value);
                              var dt = new Date(parseFloat(results[1]));
                              return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                          }
                      },
                       { "data": "contactno", "autoWidth": true },
                         {
                             "data": "CreatedDate",
                             "type": "date",
                             "render": function (value) {
                                 if (value === null) return "";

                                 var pattern = /Date\(([^)]+)\)/;
                                 var results = pattern.exec(value);
                                 var dt = new Date(parseFloat(results[1]));
                                 return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                             }
                         },
                 //{

                 //    "render": function (data, type, full, meta)
                 //    { return '<a class="btn btn-info btnEdit" href="/LabTestModule/LabRegistration/Create/' + full.regno + '">Edit</a>'; }
                 //},
                 // {
                 //     data: null, render: function (data, type, row) {
                       
                 //         return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.regno + '"); >Delete</a>';

                 //     }
                 // },
                    {
                        "render": function (data, type, full, meta)
                        { return '<a class="btn btn-info" href="/LabTestModule/LabRegistration/LoadReport?regno=' + full.regno + '">Report</a>'; }
                    },
                ]
            });
           
        });

      

        function DeleteData(regno) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(regno);
            }
            else {
                return false;
            }
        }

        function Delete(regno) {
            var url = "/LabRegistration/Delete";
            $.post(url, { regno: regno }, function (data) {
                if (data == "Deleted") {
                    window.location.href = '/LabTestModule/LabRegistration/Index'
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }

    </script>
}