@{
    ViewBag.Title = "Chart of Accounts (COA)";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>Chart of Accounts (COA)</h2>
    <p>Define Object Heads & Descriptions</p>

    <p style="float:right;">
        <a href="@Url.Action("Create", "COA", new { area = "Accounts" })" class="btn btn-primary btn-large">Add New</a>
    </p>

    <div class="container" style="width:100%;">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th style="width: 20%">Object Head Code</th>
                        <th style="width: 45%">Object Description</th>
                        <th style="width: 15%">Status</th>
                        <th style="width: 20%; min-width: 32px;"></th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Populated via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dataTable;
        $(document).ready(function() {
            loadGrid();
        });

        function loadGrid() {
            if (dataTable) {
                dataTable.destroy();
            }
            $.get("@Url.Action("LoadGrid", "COA", new { area = "Accounts" })", function(res) {
                var html = "";
                if(res.data && res.data.length > 0) {
                    $.each(res.data, function(i, item) {
                        var editUrl = '@Url.Action("Edit", "COA", new { area = "Accounts" })' + '?id=' + item.ID;
                        html += `<tr>
                            <td>${item.Code}</td>
                            <td>${item.Name}</td>
                            <td>Active</td>
                            <td>
                                <a class="btn btn-info btn-sm" href="${editUrl}">Edit</a>
                                <button class="btn btn-danger btn-sm" onclick='deleteCOA(${item.ID})'>Delete</button>
                            </td>
                        </tr>`;
                    });
                }
                $("#demoGrid tbody").html(html);
                dataTable = $('#demoGrid').DataTable();
            });
        }

        function deleteCOA(id) {
            if (confirm("Do you really want to delete this account head? This action cannot be undone.")) {
                $.post("@Url.Action("Delete", "COA", new { area = "Accounts" })", { id: id }, function(res) {
                    if (res.success) {
                        alert("Account head deleted successfully.");
                        loadGrid();
                    } else {
                        alert("Error: " + res.message);
                    }
                });
            }
        }
    </script>
}
