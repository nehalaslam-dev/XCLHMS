@model XCLHMS.Models.COA

@{
    ViewBag.Title = Model.ID == 0 ? "New Object Head" : "Edit Object Head";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>@ViewBag.Title</h2>
    <p>Define new Object Heads & Descriptions</p>
    
    <p style="float:right;">
        <a href="@Url.Action("Index", "COA", new { area = "Accounts" })" class="btn btn-default">Back to List</a>
    </p>

    <div class="container" style="width:100%; padding:0;">
        <br /><br />
        <div class="well" style="max-width: 600px;">
            @using (Html.BeginForm("Save", "COA", new { area = "Accounts" }, FormMethod.Post, new { id = "frmCOA" }))
            {
                <input type="hidden" name="ID" id="txtId" value="@Model.ID" />
                <div class="form-group">
                    <label>Object Head Code (e.g., A03901)</label>
                    @Html.TextBoxFor(m => m.Code, new { @class = "form-control", placeholder = "Enter Code", id="txtCode", required="required" })
                </div>
                <div class="form-group">
                    <label>Object Description</label>
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Enter Name of Expense Head", id="txtName", required="required" })
                </div>
                <div class="text-right" style="margin-top:20px;">
                    <button type="submit" class="btn btn-primary btn-large" id="btnSave">
                        @(Model.ID == 0 ? "Save Account Head" : "Update Account Head")
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#frmCOA").submit(function (e) {
                e.preventDefault();
                var $btn = $("#btnSave");
                var originalText = $btn.text();
                $btn.prop('disabled', true).text('Processing...');

                $.post("@Url.Action("Save", "COA", new { area = "Accounts" })", $(this).serialize(), function (res) {
                    $btn.prop('disabled', false).text(originalText);
                    if (res.success) {
                        alert("Account head saved successfully.");
                        setTimeout(() => { window.location.href = '@Url.Action("Index", "COA", new { area = "Accounts" })'; }, 500);
                    } else {
                        alert("Error: " + res.message);
                    }
                });
            });
        });
    </script>
}
