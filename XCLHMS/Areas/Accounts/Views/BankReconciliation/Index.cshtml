@{
    ViewBag.Title = "Bank Reconciliation";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>Bank Reconciliation</h2>

    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-3">
            <input type="month" id="reconMonth" class="form-control" value="2025-03" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary" onclick="loadRecon()">Load Statement</button>
        </div>
    </div>

    <div class="row well">
        <div class="col-md-4">
             <label>Balance as per Bank</label>
             <input type="number" id="bankBal" class="form-control" placeholder="PKR 0.00" />
        </div>
        <div class="col-md-4">
             <label>Balance as per Cash Book</label>
             <input type="number" id="cashBal" class="form-control" value="0.00" readonly />
        </div>
        <div class="col-md-4">
             <label>Out of balance</label>
             <h3 id="diff" style="color: #e74c3c; margin-top:5px;">PKR 0.00</h3>
        </div>
    </div>

    <div class="container" style="width:100%; padding: 0;">
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>S#</th>
                        <th>Cheque No#</th>
                        <th>Cheque Date</th>
                        <th>Cheque Amount</th>
                        <th>Cleared (Yes/No?)</th>
                        <th>Cleared Date</th>
                        <th>Outstanding</th>
                        <th>Bill No#</th>
                        <th>Name of Vendor</th>
                        <th>Object Head</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dataTable;
        $(document).ready(function() {
            loadRecon();
        });
        
        function loadRecon() {
            var val = $("#reconMonth").val();
            if(!val) return;
            var parts = val.split('-');
            var year = parts[0];
            var month = parts[1];

            if (dataTable) {
                dataTable.destroy();
            }

            $.get("@Url.Action("LoadReconciliation", "BankReconciliation", new { area = "Accounts" })", { month: month, year: year }, function(res) {
                var html = "";
                var totalOutstanding = 0;
                if(res.data && res.data.length > 0) {
                    $.each(res.data, function(i, item) {
                        var cd = item.ChequeDate ? new Date(parseInt(item.ChequeDate.substr(6))).toLocaleDateString() : '-';
                        var cld = item.ClearedDate ? new Date(parseInt(item.ClearedDate.substr(6))).toLocaleDateString() : '-';
                        var cleared = item.IsCleared ? "Yes" : "No";
                        var outstanding = item.IsCleared ? 0 : (item.Amount || 0);
                        totalOutstanding += outstanding;

                        html += `<tr>
                            <td>${i + 1}</td>
                            <td>${item.ChequeNo || '-'}</td>
                            <td>${cd}</td>
                            <td>${(item.Amount || 0).toLocaleString()}</td>
                            <td>${cleared}</td>
                            <td>${cld}</td>
                            <td>${outstanding.toLocaleString()}</td>
                            <td>${item.BillNo || '-'}</td>
                            <td>${item.VendorName || '-'}</td>
                            <td>${item.ObjectHead || '-'}</td>
                        </tr>`;
                    });
                }
                $("#demoGrid tbody").html(html);
                dataTable = $('#demoGrid').DataTable({
                    "scrollX": true
                });
            });
        }
    </script>
}
