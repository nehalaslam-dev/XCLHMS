@model XCLHMS.Models.Budget

@{
    ViewBag.Title = "Budget Allocation";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>Budget Allocation FY 2024-2025</h2>
    <p>Manage Estimates and Re-Appropriations for Departmental Heads</p>
    
    <p style="float:right;">
        <a href="@Url.Action("Index", "Budget", new { area = "Accounts" })" class="btn btn-default">Back to List</a>
    </p>

    <div class="container" style="width:100%; padding:0;">
        <br /><br />
        <div class="well">
            @using (Html.BeginForm("Save", "Budget", new { area = "Accounts" }, FormMethod.Post, new { id = "frmBudget" }))
            {
                <input type="hidden" name="Id" value="@Model.Id" />
                
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Select Account Head</label>
                        @Html.DropDownListFor(m => m.HeadId, (SelectList)ViewBag.HeadId, "--Select Head--", new { @class = "form-control", required = "required" })
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Fiscal Year</label>
                        @Html.TextBoxFor(m => m.FiscalYear, new { @class = "form-control", placeholder = "e.g. 2024-2025", @Value = Model?.FiscalYear ?? "2024-2025" })
                    </div>
                </div>

                <h4>Budget Estimates Section</h4>
                <div class="row">
                    <div class="col-md-3 form-group">
                        <label>a) Budget Estimates</label>
                        <input type="number" step="0.01" name="BudgetEstimates" id="estimates" class="form-control calc-trigger" placeholder="Enter Amount" value="@(Model?.BudgetEstimates ?? 0)" />
                    </div>
                    <div class="col-md-3 form-group">
                        <label>b) Revised Budget</label>
                        <input type="number" step="0.01" name="RevisedBudget" id="revised" class="form-control calc-trigger" placeholder="Enter Amount" value="@(Model?.RevisedBudget ?? 0)" />
                    </div>
                    <div class="col-md-3 form-group">
                        <label>c) Additional Budget</label>
                        <input type="number" step="0.01" name="AdditionalBudget" id="additional" class="form-control calc-trigger" placeholder="Enter Amount" value="@(Model?.AdditionalBudget ?? 0)" />
                    </div>
                    <div class="col-md-3 form-group">
                        <label>d) Supplementary Budget</label>
                        <input type="number" step="0.01" name="SupplementaryBudget" id="supplementary" class="form-control calc-trigger" placeholder="Enter Amount" value="@(Model?.SupplementaryBudget ?? 0)" />
                    </div>
                </div>

                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-4 form-group">
                        <label style="color:#337ab7;">e) Total Revised Budget</label>
                        <h3 id="totalRevisedDisplay" style="color: #337ab7; margin-top:5px;">Rs. @( (Model?.TotalRevisedBudget ?? 0).ToString("N2") )</h3>
                        <input type="hidden" name="TotalRevisedBudget" id="totalRevised" value="@(Model?.TotalRevisedBudget ?? 0)" />
                    </div>
                </div>

                <hr />
                <h4>RE-APPROPRIATION DETAILS</h4>
                <p>Inter-head transfers and adjustments</p>
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>f) Re-Appropriation (-)</label>
                        <input type="number" step="0.01" name="ReAppropriationNegative" id="reAppNeg" class="form-control calc-trigger" placeholder="Enter Deduction Amount" value="@(Model?.ReAppropriationNegative ?? 0)" />
                    </div>
                    <div class="col-md-4 form-group">
                        <label>g) Re-Appropriation (+)</label>
                        <input type="number" step="0.01" name="ReAppropriationPositive" id="reAppPos" class="form-control calc-trigger" placeholder="Enter Enhancement Amount" value="@(Model?.ReAppropriationPositive ?? 0)" />
                    </div>
                    <div class="col-md-4 form-group" style="background-color: #337ab7; padding: 15px; border-radius:5px;">
                        <label style="color: white;">h) Total Revised Budget after Re-app.</label>
                        <h3 id="finalTotalDisplay" style="color: white; margin-top:5px;">Calculated Balance</h3>
                        <input type="hidden" name="TotalRevisedBudgetAfterReApp" id="finalTotal" value="@(Model?.TotalRevisedBudgetAfterReApp ?? 0)" />
                    </div>
                </div>
                
                <div class="row text-right" style="margin-top: 20px;">
                    <div class="col-md-12">
                        <button type="submit" class="btn btn-primary btn-large" id="btnSave">
                            Update Budget Record
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            calculateBudget();

            $(".calc-trigger").on('input', function() {
                calculateBudget();
            });

            $("#frmBudget").submit(function (e) {
                e.preventDefault();
                var $btn = $(this).find('button[type="submit"]');
                $btn.prop('disabled', true).text('Updating record...');

                $.post("@Url.Action("Save", "Budget", new { area = "Accounts" })", $(this).serialize(), function (res) {
                    $btn.prop('disabled', false).html('Update Budget Record');
                    if (res.success) {
                        alert("Budget record has been updated.");
                        setTimeout(() => { window.location.href = '@Url.Action("Index", "Budget", new { area = "Accounts" })'; }, 1500);
                    } else {
                        alert("Error! " + res.message);
                    }
                });
            });
        });

        function calculateBudget() {
            var a = parseFloat($("#estimates").val()) || 0;
            var b = parseFloat($("#revised").val()) || 0;
            var c = parseFloat($("#additional").val()) || 0;
            var d = parseFloat($("#supplementary").val()) || 0;

            var e = a + b + c + d;
            $("#totalRevised").val(e);
            $("#totalRevisedDisplay").text("Rs. " + e.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }));

            var f = parseFloat($("#reAppNeg").val()) || 0;
            var g = parseFloat($("#reAppPos").val()) || 0;

            var h = e - f + g;
            $("#finalTotal").val(h);
            $("#finalTotalDisplay").text("Rs. " + h.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
        }
    </script>
}
