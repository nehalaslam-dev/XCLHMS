@{
    ViewBag.Title = "Budget Allocation";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>Budget List</h2>
    <p>Manage and monitor departmental budget allocations</p>

    <p style="float:right;">
        <a href="@Url.Action("Create", "Budget", new { area = "Accounts" })" class="btn btn-primary btn-large">Add New</a>
    </p>

    <div class="container" style="width:100%;">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th rowspan="2" style="vertical-align: middle;">Head Name</th>
                        <th rowspan="2" style="vertical-align: middle;">Code</th>
                        <th colspan="3" class="text-center">Allocation</th>
                        <th colspan="3" class="text-center">Adjustments</th>
                        <th rowspan="2" style="vertical-align: middle;">Final Budget</th>
                    </tr>
                    <tr>
                        <th>Estimates</th>
                        <th>Revised</th>
                        <th>Additional</th>
                        <th>Supp.</th>
                        <th>Re-App(+)</th>
                        <th>Re-App(-)</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Data loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title">Confirm Delete</h4>
            </div>
            <div class="modal-body text-center p-5">
                <p>Are you sure you want to remove this budget allocation? This cannot be undone.</p>
                <input type="hidden" id="deleteId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dataTable;
        $(document).ready(function () {
            loadGrid();
        });

        function loadGrid() {
            if (dataTable) {
                dataTable.destroy();
            }
            $.get("@Url.Action("LoadGrid", "Budget", new { area = "Accounts" })", function (res) {
                var html = "";
                if (res.data && res.data.length > 0) {
                    $.each(res.data, function (i, item) {
                        html += `<tr>
                            <td>${item.COA ? item.COA.Name : 'No Head'}</td>
                            <td>${item.COA ? item.COA.Code : '-'}</td>
                            <td>${ (item.BudgetEstimates || 0).toLocaleString() }</td>
                            <td>${ (item.RevisedBudget || 0).toLocaleString() }</td>
                            <td>${ (item.AdditionalBudget || 0).toLocaleString() }</td>
                            <td>${ (item.SupplementaryBudget || 0).toLocaleString() }</td>
                            <td>${ (item.ReAppropriationPositive || 0).toLocaleString() }</td>
                            <td>${ (item.ReAppropriationNegative || 0).toLocaleString() }</td>
                            <td style="font-weight:bold; color:green;">${ (item.TotalRevisedBudgetAfterReApp || 0).toLocaleString() }</td>
                        </tr>`;
                    });
                }
                $("#demoGrid tbody").html(html);
                dataTable = $('#demoGrid').DataTable({
                    "scrollX": true
                });
            });
        }

        function openDelete(id) {
            $("#deleteId").val(id);
            $("#deleteModal").modal('show');
        }

        function confirmDelete() {
            var id = $("#deleteId").val();
            $("#deleteModal").modal('hide');
            $.post("@Url.Action("Delete", "Budget", new { area = "Accounts" })", { Id: id }, function (res) {
                if (res == "Deleted" || res.success) {
                    alert("Budget record deleted successfully.");
                    loadGrid();
                } else {
                    alert("Failed to delete record.");
                }
            });
        }
    </script>
}