@{
    ViewBag.Title = "Tax Configuration";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>Tax Configuration</h2>

    <p style="float:right;">
        <button class="btn btn-primary btn-large" onclick="openModal()">Add New</button>
    </p>
    
    <div class="container" style="width:100%;">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Tax Rule</th>
                        <th>Percentage (%)</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th style="width: 32px;"></th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="taxModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Tax Configuration</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="taxId" value="0" />
                <div class="form-group">
                    <label>Tax Name</label>
                    <input type="text" id="taxName" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Tax Percentage (%)</label>
                    <input type="number" step="0.01" id="taxPct" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" id="taxDesc" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveTax()">Save changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dataTable;
        $(document).ready(function() {
            loadGrid();
        });

        function loadGrid() {
            if (dataTable) {
                dataTable.destroy();
            }
            $.get("@Url.Action("LoadTaxes", "TaxConfiguration", new { area = "Accounts" })", function(res) {
                var html = "";
                if(res.data && res.data.length > 0) {
                    $.each(res.data, function(i, item) {
                        var status = item.IsActive ? 'Active' : 'Inactive';
                        html += `<tr>
                            <td>${item.TaxName}</td>
                            <td>${item.TaxPercentage}</td>
                            <td>${item.Description || '-'}</td>
                            <td>${status}</td>
                            <td>
                                <button class="btn btn-info btn-sm" onclick='editTax(${JSON.stringify(item)})'>Edit</button>
                            </td>
                        </tr>`;
                    });
                }
                $("#demoGrid tbody").html(html);
                dataTable = $('#demoGrid').DataTable();
            });
        }

        function openModal() {
            $("#taxId").val(0);
            $("#taxName").val("");
            $("#taxPct").val("");
            $("#taxDesc").val("");
            $("#taxModal").modal("show");
        }

        function editTax(item) {
            $("#taxId").val(item.ID);
            $("#taxName").val(item.TaxName);
            $("#taxPct").val(item.TaxPercentage);
            $("#taxDesc").val(item.Description);
            $("#taxModal").modal("show");
        }

        function saveTax() {
            var model = {
                ID: $("#taxId").val(),
                TaxName: $("#taxName").val(),
                TaxPercentage: $("#taxPct").val(),
                Description: $("#taxDesc").val(),
                IsActive: true
            };

            $.post("@Url.Action("SaveTax", "TaxConfiguration", new { area = "Accounts" })", model, function(res) {
                if(res.success) {
                    $("#taxModal").modal("hide");
                    loadGrid();
                } else {
                    alert("Error: " + res.message);
                }
            });
        }
    </script>
}
