@section Scripts{
    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/AccountLedger/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [
                   { "data": "voucherNumber", "autoWidth": true },
                   {
                       "data": "voucherDate",
                       "type": "date",
                       "render": function (value) {
                           if (value === null) return "";

                           var pattern = /Date\(([^)]+)\)/;
                           var results = pattern.exec(value);
                           var dt = new Date(parseFloat(results[1]));
                           return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                       }
                   },
                    { "data": "Description", "autoWidth": true },
                     { "data": "IsPosted", "autoWidth": true },
                      {
                          "render": function (data, type, full, meta)
                          { return '<a class="btn btn-info" href="/Accounts/AccountLedger/Details/' + full.Id + '">Details</a>'; }
                      },
                       {
                           "render": function (data, type, full, meta)
                           { return '<a class="btn btn-info" href="/Accounts/AccountLedger/Create/' + full.Id + '">Edit</a>'; }
                       },
                       {
                           data: null, render: function (data, type, row) {
                               return "<a  class='btn btn-danger' onclick=DeleteData('" + row.Id + "'); >Delete</a>";
                           }
                       },
                ]
            });
        });

        function DeleteData(ledgerId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(ledgerId);
            }
            else {
                return false;
            }
        }

        function Delete(ledgerId) {
            var url = "/AccountLedger/Delete";
            $.post(url, { Id: ledgerId }, function (data) {
                if (data == "Deleted") {
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();
                    window.location.href = '/Accounts/AccountLedger/Index'
                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}
