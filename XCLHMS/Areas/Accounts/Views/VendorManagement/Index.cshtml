@{
    ViewBag.Title = "Vendor Management";
    Layout = "~/Areas/Accounts/Views/Shared/_AccountsLayout.cshtml";
}

<div style="font-family:Arial">
    <h2>Vendor Management</h2>
    
    <p style="float:right;">
        <button class="btn btn-primary btn-large" onclick="openModal()">Add Vendor</button>
    </p>

    <div class="container" style="width:100%;">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Vendor ID</th>
                        <th>Name</th>
                        <th>NTN</th>
                        <th>CNIC</th>
                        <th>Status</th>
                        <th>Payment Sec</th>
                        <th style="width: 32px;"></th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="vendorModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title" id="myModalLabel">Vendor Registration</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="vId" value="0" />
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Tax-Payer Name</label>
                        <input type="text" id="vName" class="form-control" />
                    </div>
                    <div class="col-md-4 form-group">
                        <label>NTN No.</label>
                        <input type="text" id="vNTN" class="form-control" />
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Tax-Payer CNIC</label>
                        <input type="text" id="vCNIC" class="form-control" />
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Tax-Payer City</label>
                        <input type="text" id="vCity" class="form-control" />
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Tax-Payer Status</label>
                        <select id="vStatus" class="form-control">
                            <option value="Individual">Individual</option>
                            <option value="Company">Company</option>
                        </select>
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Payment Section</label>
                        <select id="vPaymentSection" class="form-control">
                            <optgroup label="Goods">
                                <option value="Goods 153(1)(a)/4 Company">153(1)(a)/4 Company</option>
                                <option value="Goods 153(1)(a)/5 Individual">153(1)(a)/5 Individual</option>
                            </optgroup>
                            <optgroup label="Services">
                                <option value="Services 153(1)(b)/4 Company">153(1)(b)/4 Company</option>
                                <option value="Services 153(1)(b)/5 Individual">153(1)(b)/5 Individual</option>
                            </optgroup>
                        </select>
                    </div>
                    <div class="col-md-12 form-group">
                        <label>Tax-Payer Address</label>
                        <input type="text" id="vAddress" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveVendor()">Save changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dataTable;
        $(document).ready(function() {
            loadGrid();
        });

        function loadGrid() {
            if (dataTable) {
                dataTable.destroy();
            }
            $.get("@Url.Action("LoadGrid", "VendorManagement", new { area = "Accounts" })", function(res) {
                var html = "";
                if(res.data && res.data.length > 0) {
                    $.each(res.data, function(i, item) {
                        html += `<tr>
                            <td>VND-${item.Id}</td>
                            <td>${item.Name || '-'}</td>
                            <td>${item.NTN || '-'}</td>
                            <td>${item.CNIC || '-'}</td>
                            <td>${item.Status || '-'}</td>
                            <td>${item.PaymentSection || '-'}</td>
                            <td>
                                <button class="btn btn-info btn-sm" onclick='editVendor(${JSON.stringify(item)})'>Edit</button>
                            </td>
                        </tr>`;
                    });
                }
                $("#demoGrid tbody").html(html);
                dataTable = $('#demoGrid').DataTable();
            });
        }

        function openModal() {
            $("#vId").val(0);
            $("#vName, #vNTN, #vCNIC, #vCity, #vAddress").val("");
            $("#vStatus").val("Individual");
            $("#vendorModal").modal("show");
        }

        function editVendor(item) {
            $("#vId").val(item.Id);
            $("#vName").val(item.Name);
            $("#vNTN").val(item.NTN);
            $("#vCNIC").val(item.CNIC);
            $("#vCity").val(item.Code); // Using Code as City
            $("#vAddress").val(item.Address);
            $("#vStatus").val(item.Status);
            $("#vPaymentSection").val(item.PaymentSection);
            $("#vendorModal").modal("show");
        }

        function saveVendor() {
            var model = {
                Id: $("#vId").val(),
                Name: $("#vName").val(),
                NTN: $("#vNTN").val(),
                CNIC: $("#vCNIC").val(),
                Code: $("#vCity").val(), // Code maps to City
                Address: $("#vAddress").val(),
                Status: $("#vStatus").val(),
                PaymentSection: $("#vPaymentSection").val(),
                Active: true
            };

            $.post("@Url.Action("Save", "VendorManagement", new { area = "Accounts" })", model, function(res) {
                if(res.success) {
                    $("#vendorModal").modal("hide");
                    loadGrid();
                } else {
                    alert("Error: " + res.message);
                }
            });
        }
    </script>
}
