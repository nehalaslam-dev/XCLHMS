@model XCLHMS.Models.AccountRegister

@{
    ViewBag.Title = "Create";
}

<h2>Create</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Account Register</h4>
        <hr />
        @Html.ValidationSummary(true)

        <div class="form-group">
            @Html.LabelFor(model => model.HeadId, "Select Head", new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                @Html.DropDownList("HeadId", (IEnumerable<SelectListItem>)ViewBag.HeadId, "--Select--", new { @class = "form-control" })
                <span class="error">select account head.</span>
            </div>
            <div class="col-md-5">
                @Html.Label("Code", null, new { @class = "control-label col-md-2" })
                @Html.TextBox("Code", null, new { @class = "form-control", @disabled = "disabled" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.BillNo, new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                @Html.TextBoxFor(model => model.BillNo, new { @class = "form-control" })
                <span class="error">Bill no required.</span>
            </div>
            <div class="col-md-5">
                @Html.Label("Date", new { @class = "control-label col-md-2" })
                @Html.TextBoxFor(model => model.billdate, new { @class = "date form-control" })
                <span class="error">Bill date required.</span>
            </div>
        </div>
        <div class="form-group">
            @Html.LabelFor(model => model.VendorId, "Account Name (M/S)", new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                @Html.DropDownList("VendorId", (IEnumerable<SelectListItem>)ViewBag.VendorId, "--Select--", new { @class = "form-control" })
                <span class="error">select account name.</span>
            </div>
            <div class="col-md-5">
                @Html.Label("Cheque", new { @class = "control-label col-md-2" })
                @Html.TextBoxFor(model => model.ChequeNo, new { @class = "form-control" })
                <span class="error">Cheque required.</span>
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Allot Budget", new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                @Html.TextBoxFor(model => model.AnnualBudget, new { @class = "form-control", @disabled = "disabled" })
                @Html.ValidationMessageFor(model => model.AnnualBudget)
            </div>
            <div class="col-md-5">
                @Html.Label("Billed Amount", new { @class = "control-label col-md-2" })
                @Html.TextBoxFor(model => model.BudgetRelease, new { @class = "form-control" })
                <span class="error">Budget required.</span>
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.EntryType, "Select EntryType", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("EntryType", new List<SelectListItem> {
                    new SelectListItem{Text="Revenue",Value="Revenue"},
                    new SelectListItem{Text="Expense",Value="Expense"}}, "-- Select --", new { @class = "form-control" })
                <span class="error">EntryType required.</span>
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Tax", new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                @Html.DropDownList("TaxId", null, new { @class = "form-control" })

            </div>
            <div class="col-md-5">
                @Html.Label("Sub Tax", new { @class = "control-label col-md-2" })
                @Html.DropDownList("subTax", null, new { @class = "form-control" })
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Tax", new { @class = "control-label col-md-2" })
            <div class="col-md-5">
                @Html.DropDownList("SecTaxId", null, new { @class = "form-control" })

            </div>
            <div class="col-md-5">
                @Html.Label("Sub Tax", new { @class = "control-label col-md-2" })
                @Html.DropDownList("SecsubTax", null, new { @class = "form-control" })
            </div>
        </div>

        <div class="row">
            <div class="col-auto">
                <a id="addToList" class="btn btn-primary pull-right">Add To List</a>
            </div>
        </div>
    </div>
}
<hr />
<div class="container">
    <br />
    <div style="width:100%; margin:0 auto;">
        <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
            <thead>
                <tr>
                    <th>Entry Type</th>
                    <th>Bill No</th>
                    <th>Dated</th>
                    <th>Vendor</th>
                    <th>Cheque</th>
                    <th>Alloted Budget</th>
                    <th>Billed Amount</th>
                    <th>Income Tax</th>
                    <th>SST</th>
                    <th>Net Amount Paid</th>
                    <th>Balance in Head</th>
                    <th class="th-width"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>


    <div style="padding:10px 0; text-align:right">
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary" })
        <input id="submit" type="button" value="Save" class="btn btn-warning" />
    </div>
</div>

<script src="~/Scripts/jquery-1.12.4.js"></script>
<script src="~/Scripts/AccountsRegister.js"></script>
<style>
    span.error {
        display: block;
        visibility: hidden;
        color: red;
        font-size: 90%;
    }

    tr.error {
        background-color: rgba(255,0,0,0.35);
    }
</style>
@section Scripts{
    <script>
        $(document).ready(function () {
            if ($('#TaxId').val() == '0') {
                var dutyDefaultValue = "<option value='0'>--Select--</option>";
                $("#subTax").html(dutyDefaultValue).show();
            }

            if ($('#SecTaxId').val() == '0') {
                var dutyDefaultValue = "<option value='0'>--Select--</option>";
                $("#SecsubTax").html(dutyDefaultValue).show();
            }

            $('#TaxId').change(function () {
                var selectedItemValue = $(this).val();
                var ddlSubTax = $("#subTax");
                $.ajax({
                    cache: false,
                    type: "GET",
                    url: "/Accounts/AccountRegister/GetTaxById",
                    data: { "id": selectedItemValue },
                    success: function (data) {
                        ddlSubTax.html('');
                        $.each(data, function (id, option) {
                            ddlSubTax.append($('<option></option>').val(option.id).html(option.name));
                        });
                    },
                    error: function (xhr, ajaxOptions, thrownError) {
                        alert('Found error to load!!.');
                    }
                });
            });

            $('#SecTaxId').change(function () {
                var selectedItemValue = $(this).val();
                var ddlSubTax = $("#SecsubTax");
                $.ajax({
                    cache: false,
                    type: "GET",
                    url: "/Accounts/AccountRegister/GetTaxById",
                    data: { "id": selectedItemValue },
                    success: function (data) {
                        ddlSubTax.html('');
                        $.each(data, function (id, option) {
                            ddlSubTax.append($('<option></option>').val(option.id).html(option.name));
                        });
                    },
                    error: function (xhr, ajaxOptions, thrownError) {
                        alert('Found error to load!!.');
                    }
                });
            });
        });
    </script>
}