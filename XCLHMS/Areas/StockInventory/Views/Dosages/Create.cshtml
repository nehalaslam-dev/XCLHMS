@model XCLHMS.Models.Dosage

@{
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Create</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Dosage</h4>
        <hr />
        @Html.ValidationSummary(true)

        <div class="form-group">
            @Html.LabelFor(model => model.AUId, "AU", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("AUId", (IEnumerable<SelectListItem>)ViewBag.AUId, "--Select--", new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.AUId)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.DosageName, "Dosage Name", new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.DosageName, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.DosageName)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Description, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.Description, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.Description)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.Active, new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.CheckBox("Active")
                @Html.ValidationMessageFor(model => model.Active)
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Save" class="btn btn-primary btn-success" />
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-primary btn-large" })
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Agar checkbox unchecked hai to usay default checked kar do
            if (!$('#Active').is(':checked')) {
                $('#Active').prop('checked', true);
            }
        });
    </script>
}


