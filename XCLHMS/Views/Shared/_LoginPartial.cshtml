            <li>@Html.ActionLink("Log in", "Login", "Account", routeValues: null, htmlAttributes: new { id = "loginLink" })</li>
        </ul>*@
}



<script>

    jQuery(function () {

        var _EmpID = jQuery('#hdnEmployeeID').val();
        if (parseInt(_EmpID) <= 0) {
            window.location.href = '/Login/LogOut';
        }

    });

</script>
