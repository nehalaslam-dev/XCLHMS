@foreach (var item in XCLHMS.Helpers.SessionHelper.CurrentMenus)
{
    if (item.HasChild)
    {
        <li class="dropdown">
            <a href="#">
                @item.Name
            </a>
            <ul class="dropdown-menu">
                @foreach (var Subitem in item.ChildMenu)
                {
                    if (Subitem.HasChild)
                    {
                        <li class="dropdown">
                            <a href="#">
                                @Subitem.Name
                            </a>
                            <ul class="dropdown-menu">
                                @foreach (var SubitemChild in Subitem.ChildMenu)
                                {
                                    <li>
                                        <a href="@SubitemChild.Path">
                                            @SubitemChild.Name
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li>
                            <a href="@Subitem.Path">
                                @Subitem.Name

                            </a>
                        </li>
                    }
                }
            </ul>
        </li>
    }
    else
    {
        <li>
            <a href="@item.Path">
                @item.Name
            </a>
        </li>
    }
}
<li>
    <a href="/PatientModule/PatientReport/PatientReport.aspx">Patient Report</a>
</li>


