@model XCLHMS.Models.CreateApplicationModel
@{
    ViewBag.Title = "AddEdit CreateApplication";
    Layout = "~/Views/Shared/_Layout.cshtml";
}




<div class="content container-fluid">
    <div class="row">
        <div class="col-md-8 col-md-offset-2">
            @using (Html.BeginForm("AddEditApplicationSave", "CreateApplication", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <h3 class="page-title">ADD/Edit EmployeeRole</h3>
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                @Html.HiddenFor(x => x.menuID)
                @Html.HiddenFor(x => x.menuParentID)
                <div class="row">

                    <div class="col-sm-6">
                        <div class="form-group">
                            @Html.LabelFor(x => x.menuName)
                            @Html.TextBoxFor(x => x.menuName, new { @class = "form-control" })
                        </div>
                    </div>
                </div>

                <div class="row">

                    <div class="col-sm-6">
                        <div class="form-group">
                            @Html.LabelFor(x => x.applicationPath)
                            @Html.TextBoxFor(x => x.applicationPath, new { @class = "form-control" })
                        </div>
                    </div>
                </div>


                <div class="row">
                    <div class="row">
                        <div class="col-sm-12 text-center m-t-20">

                            <a href="javascript:void(0);" class="btn btn-primary pull-right rounded btnBack"><i class="fa fa-plus"></i>Cancel</a>
                            <button type="submit" class="btn btn-primary">Save &amp; update</button>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
               
@section Scripts {

    @Scripts.Render("~/bundles/jqueryval")
}
<script type="text/javascript">

    jQuery(function () {
        var _curr = jQuery('#menuParentID').val();
        if (parseInt(_curr) > 0)
        {
            jQuery('.btnBack').attr('href', '/CreateApplication/ManageCreateApplication?parentid=' + _curr);
        }
        else
        {
            jQuery('.btnBack').attr('href', '/CreateApplication/ManageCreateApplication');
        }

    });

</script>

