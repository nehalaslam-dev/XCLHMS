@model IEnumerable<XCLHMS.Models.Department>

@{
    ViewBag.Title = "Index";
}
<style>
    .th-width {
        width: 32px !important;
    }
</style>
<div style="font-family:Arial">
    <h2>Department List</h2>
    <p style="float:right;">
        @Html.ActionLink("Add New", "Create", null, new { @class = "btn btn-primary btn-large btnAdd" })
    </p>
    <div class="container">
        <br />
        <div style="width:100%; margin:0 auto;">
            <table id="demoGrid" class="table table-striped table-bordered dt-responsive nowrap" width="100%" cellspacing="0">
                <thead>
                    <tr>

                        <th>Dept Code</th>
                        <th>Department Name</th>
                        <th>Active</th>
                        <th class="th-width"></th>
                        <th class="th-width"></th>
                    </tr>
                </thead>
            </table>
        </div>
        @Html.Hidden("hdnPageSecurity", @XCLHMS.Helpers.SessionHelper.GetPageSecurity())
    </div>
</div>
@section Scripts{

    <script>
        $(document).ready(function () {
            $('#demoGrid').DataTable({
                "ajax": {
                    "url": "/Department/LoadGrid",
                    "type": "GET",
                    "datatype": "json"
                },


                "columnDefs": [{
                    "targets": 4,
                    "orderable": false,
                }],

                "fnRowCallback": function (nRow, aData, iDisplayIndex) {

                    var arr1 = jQuery('#hdnPageSecurity').val().split('|');
                    var _valIsAdd = arr1[0];
                    var _valIsEdit = arr1[1];
                    var _valIsDelete = arr1[2];
                    if (_valIsAdd == '1') {
                        $('.btnAdd').removeAttr('disabled');
                    }
                    else {
                        $('.btnAdd').attr('disabled', 'disabled');
                    }

                    if (_valIsEdit == '1') {

                        $('td:eq(3)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(3)', nRow).find('a').attr('disabled', 'disabled');
                    }

                    if (_valIsDelete == '1') {
                        $('td:eq(4)', nRow).find('a').removeAttr('disabled');
                    }
                    else {
                        $('td:eq(4)', nRow).find('a').attr('disabled', 'disabled');
                    }
                },

                "columns": [

                    { "data": "DeptCode", "autoWidth": true },
                    { "data": "DepartmentName", "autoWidth": true },
                    { "data": "Active", "autoWidth": true },
                    {
                        "render": function (data, type, full, meta) { return '<a class="btn btn-info btnEdit" href="/Department/Edit/' + full.Id + '">Edit</a>'; }
                    },
                    {
                        data: null, render: function (data, type, row) {
                            return '<a href="javascript:void(0);" class="btn btn-danger btnDelete" onclick=DeleteData("' + row.Id + '"); >Delete</a>';
                        }
                    },
                ]
            });

        });

        function DeleteData(deptId) {
            if (confirm("Are you sure you want to delete ...?")) {
                Delete(deptId);
            }
            else {
                return false;
            }
        }

        function Delete(deptId) {
            var url = "/Department/Delete";
            $.post(url, { Id: deptId }, function (data) {
                if (data == "Deleted") {
                    window.location.href = '/Department/Index'
                    alert("Record has been deleted!");
                    oTable = $('#demoGrid').DataTable();
                    oTable.draw();

                }
                else if (data == "Exists") {
                    alert("Record can not delete,associate with other record!");
                }
                else {
                    alert("Something went Wrong!");
                }
            });
        }
    </script>
}
