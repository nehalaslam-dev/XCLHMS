		<Height>1in</Height>
	</Body>
	<Width>10.5in</Width>
	<Page>
		<PageHeader>
			<Height>1in</Height>
			<PrintOnFirstPage>true</PrintOnFirstPage>
			<PrintOnLastPage>true</PrintOnLastPage>
			<ReportItems>
				<Textbox Name="HospitalName">
					<Paragraphs>
						<Paragraph>
							<TextRuns>
								<TextRun>
									<Value>SAYED ABDULLAH SHAH INSTITUTE OF MEDICAL SCIENCE SEHWAN</Value>
									<Style>
										<FontSize>12pt</FontSize>
										<FontWeight>Bold</FontWeight>
										<Color>#7f8c8d</Color>
									</Style>
								</TextRun>
							</TextRuns>
							<Style>
								<TextAlign>Center</TextAlign>
							</Style>
						</Paragraph>
					</Paragraphs>
					<Top>0.05in</Top>
					<Height>0.25in</Height>
					<Width>10.5in</Width>
				</Textbox>
				<Textbox Name="ReportTitle">
					<Paragraphs>
						<Paragraph>
							<TextRuns>
								<TextRun>
									<Value>Patient Summary Report</Value>
									<Style>
										<FontSize>16pt</FontSize>
										<FontWeight>Bold</FontWeight>
										<TextDecoration>Underline</TextDecoration>
									</Style>
								</TextRun>
							</TextRuns>
							<Style>
								<TextAlign>Center</TextAlign>
							</Style>
						</Paragraph>
					</Paragraphs>
					<Top>0.4in</Top>
					<Height>0.4in</Height>
					<Width>10.5in</Width>
				</Textbox>
				<Textbox Name="PrintDate">
					<Paragraphs>
						<Paragraph>
							<TextRuns>
								<TextRun>
									<Value>="Print Date: " &amp; Format(Globals!ExecutionTime, "d MMM yyyy")</Value>
									<Style>
										<FontSize>8pt</FontSize>
									</Style>
								</TextRun>
							</TextRuns>
							<Style>
								<TextAlign>Right</TextAlign>
							</Style>
						</Paragraph>
					</Paragraphs>
					<Top>0.1in</Top>
					<Left>8in</Left>
					<Height>0.2in</Height>
					<Width>2.5in</Width>
				</Textbox>
			</ReportItems>
		</PageHeader>
		<PageFooter>
			<Height>0.5in</Height>
			<ReportItems>
				<Textbox Name="FooterL">
					<Paragraphs>
						<Paragraph>
							<TextRuns>
								<TextRun>
									<Value>="Generated on: " &amp; Globals!ExecutionTime</Value>
									<Style>
										<FontSize>8pt</FontSize>
										<Color>#7f8c8d</Color>
									</Style>
								</TextRun>
							</TextRuns>
						</Paragraph>
					</Paragraphs>
					<Top>0.1in</Top>
					<Height>0.2in</Height>
					<Width>3in</Width>
				</Textbox>
				<Textbox Name="FooterR">
					<Paragraphs>
						<Paragraph>
							<TextRuns>
								<TextRun>
									<Value>="Page " &amp; Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value>
									<Style>
										<FontSize>8pt</FontSize>
										<Color>#7f8c8d</Color>
									</Style>
